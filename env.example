# Vercel Blob: crea un store en https://vercel.com/dashboard/stores
# y copia el token "Read and Write" del blob store al desplegar o en local.
# Con este token, además de subir fotos, se guarda una copia del catálogo en
# tyd/catalog.json para recuperarlo entre navegadores o si se borra el almacenamiento local.
BLOB_READ_WRITE_TOKEN=
